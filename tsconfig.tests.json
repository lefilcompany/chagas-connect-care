{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "types": ["vitest/globals", "node", "vite/client"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/test/**/*.ts",
    "src/test/**/*.tsx",
    "tests/e2e/**/*.ts",
    "playwright.config.ts"
  ]
}
